{
  "name": "llmpeek",
  "version": "0.1.0",
  "description": "Local-first devtools for LLM apps — one import (or a local proxy) and every LLM API call your app makes shows up live in a localhost dashboard: prompts, tool calls, streaming, tokens, latency, cost. No account, no config.",
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "devtools",
    "observability",
    "debugging",
    "proxy",
    "interceptor",
    "prompt",
    "tokens",
    "cost",
    "ai"
  ],
  "license": "MIT",
  "author": "Kristofers Gulbis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kristofers322/llmpeek.git"
  },
  "homepage": "https://github.com/kristofers322/llmpeek#readme",
  "bugs": {
    "url": "https://github.com/kristofers322/llmpeek/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "edge-light": "./dist/noop.js",
      "worker": "./dist/noop.js",
      "workerd": "./dist/noop.js",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "llmpeek": "./dist/proxy-cli.js"
  },
  "files": ["dist", "dashboard", "pricing.json"],
  "engines": {
    "node": ">=18.19"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-dashboard.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@mswjs/interceptors": "^0.41.9",
    "node-forge": "^1.4.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node-forge": "^1.3.14",
    "tsup": "^8.5.1"
  }
}
